#!/bin/bash

# daily-claude: AddTask
# Quickly add a task to your TASKS.md from anywhere.
# https://github.com/nawzaysfinah/daily-claude

CONFIG_FILE="$HOME/.daily-claude"

# ── First-run setup ────────────────────────────────────────────────────────────
if [ ! -f "$CONFIG_FILE" ]; then
  # Welcome message
  osascript -e 'display dialog "Welcome to daily-claude! 👋

Let'\''s set up your TASKS.md file. In the next step, choose (or create) a folder where your tasks will live." with title "daily-claude Setup" buttons {"Get Started"} default button "Get Started"' 2>/dev/null

  # Let user pick a folder
  CHOSEN_DIR=$(osascript -e 'tell application "Finder"
    set chosenFolder to choose folder with prompt "Choose a folder for your TASKS.md:"
    return POSIX path of chosenFolder
  end tell' 2>/dev/null)

  if [ -z "$CHOSEN_DIR" ]; then
    exit 0  # User cancelled
  fi

  # Remove trailing slash
  CHOSEN_DIR="${CHOSEN_DIR%/}"
  TASKS_FILE="$CHOSEN_DIR/TASKS.md"

  # Save config
  echo "TASKS_FILE=$TASKS_FILE" > "$CONFIG_FILE"

  # Create TASKS.md if it doesn't exist
  if [ ! -f "$TASKS_FILE" ]; then
    cat > "$TASKS_FILE" << 'TEMPLATE'
# Tasks

<!-- daily-claude: Claude reads this file each morning for your daily briefing. -->
<!-- Format: - [ ] Task description -->

## 🔴 Today

- [ ] Your first task — replace me!

## 🟡 This Week


## 🟢 Backlog


---
TEMPLATE
    echo "_Created: $(date '+%Y-%m-%d')_" >> "$TASKS_FILE"
  fi

  osascript -e "display notification \"TASKS.md created at $TASKS_FILE\" with title \"daily-claude ready ✓\""
fi

# ── Load config ────────────────────────────────────────────────────────────────
source "$CONFIG_FILE"

# Resolve scripts directory — try repo-relative first, then Desktop fallback
BUNDLE_PARENT="$(dirname "$(dirname "$(dirname "$0")")")"
if [ -f "$BUNDLE_PARENT/scripts/parse_when.py" ]; then
  SCRIPTS_DIR="$BUNDLE_PARENT/scripts"
elif [ -f "$HOME/Desktop/daily-claude-scripts/parse_when.py" ]; then
  SCRIPTS_DIR="$HOME/Desktop/daily-claude-scripts"
else
  SCRIPTS_DIR=""
fi

if [ ! -f "$TASKS_FILE" ]; then
  ACTION=$(osascript -e 'display dialog "TASKS.md not found at the saved path. What would you like to do?" with title "daily-claude Error" buttons {"Cancel", "Reset Config"} default button "Reset Config"' -e 'button returned of result' 2>/dev/null)
  if [ "$ACTION" = "Reset Config" ]; then
    rm -f "$CONFIG_FILE"
    exec "$0"  # Relaunch to trigger first-run setup
  fi
  exit 1
fi

# ── Pick a category ────────────────────────────────────────────────────────────
CATEGORY=$(osascript -e 'choose from list {"🔴 Today", "🟡 This Week", "🟢 Backlog"} with title "Add Task" with prompt "Which list?" default items {"🔴 Today"}' 2>/dev/null)

if [ "$CATEGORY" = "false" ] || [ -z "$CATEGORY" ]; then
  exit 0
fi

# Map emoji label to section header
case "$CATEGORY" in
  "🔴 Today")    SECTION="## 🔴 Today" ;;
  "🟡 This Week") SECTION="## 🟡 This Week" ;;
  "🟢 Backlog")  SECTION="## 🟢 Backlog" ;;
esac

# ── Get task text ──────────────────────────────────────────────────────────────
TASK=$(osascript -e 'display dialog "What'\''s your task?" with title "Add Task" default answer "" buttons {"Cancel", "Add ✓"} default button "Add ✓"' -e 'text returned of result' 2>/dev/null)

if [ -z "$TASK" ]; then
  exit 0
fi

# ── Insert task under the correct section ──────────────────────────────────────
# Use Python for reliable section-aware insertion
python3 - "$TASKS_FILE" "$SECTION" "$TASK" << 'PYEOF'
import sys

tasks_file = sys.argv[1]
section = sys.argv[2]
task = sys.argv[3]
new_line = f"- [ ] {task}"

with open(tasks_file, 'r') as f:
    lines = f.readlines()

inserted = False
result = []
i = 0
in_section = False

while i < len(lines):
    line = lines[i]
    stripped = line.strip()

    if stripped == section:
        in_section = True
        result.append(line)
        i += 1
        continue

    if in_section and (stripped.startswith('## ') or stripped == '---'):
        # End of section — normalize and insert task at bottom
        # Strip trailing blank lines accumulated in this section
        while result and result[-1].strip() == '':
            result.pop()
        result.append('\n')            # one blank line before task
        result.append(new_line + '\n')
        result.append('\n')            # one blank line after task
        inserted = True
        in_section = False

    result.append(line)
    i += 1

# Section was the last block in the file (no trailing ## or ---)
if in_section and not inserted:
    while result and result[-1].strip() == '':
        result.pop()
    result.append('\n')
    result.append(new_line + '\n')
    result.append('\n')
    inserted = True

# Section header not found — append a new section
if not inserted:
    result.append(f'\n{section}\n\n{new_line}\n\n')

with open(tasks_file, 'w') as f:
    f.writelines(result)
PYEOF

osascript -e "display notification \"Added to $CATEGORY\" with title \"$TASK ✓\""

# ── Optional: Add to Google Calendar ───────────────────────────────────────────
# Require parse_when.py to be available
if [ -z "$SCRIPTS_DIR" ] || [ ! -f "$SCRIPTS_DIR/parse_when.py" ]; then
  exit 0
fi

# Safe display version for osascript prompts (strip " and ')
DISPLAY_TASK="${TASK//\"/}"
DISPLAY_TASK="${DISPLAY_TASK//\'/}"

CAL_CHOICE=$(osascript -e 'choose from list {"Yes", "No"} with title "Add to Calendar?" with prompt "'"$DISPLAY_TASK"'" default items {"No"}' 2>/dev/null)

if [ "$CAL_CHOICE" != "Yes" ]; then
  exit 0
fi

# Extract raw date/time hint from task text for dialog pre-fill
RAW_HINT=$(python3 - "$TASK" << 'HINTEOF'
import sys, re
task = sys.argv[1]
fragments = []
t = re.search(r'\b\d{1,2}(?::\d{2})?\s*(?:am|pm)\b', task, re.IGNORECASE)
if t: fragments.append(t.group(0).strip())
d = re.search(r'\b(?:today|tomorrow|monday|tuesday|wednesday|thursday|friday|saturday|sunday|mon|tue|wed|thu|fri|sat|sun)\b', task, re.IGNORECASE)
if d: fragments.append(d.group(0).strip())
print(' '.join(fragments))
HINTEOF
)

WHEN=$(osascript -e "display dialog \"When is this event?\\n\\nExamples: \\\"tomorrow 2pm\\\", \\\"Monday 3pm\\\", \\\"June 10 9am\\\"\" with title \"Add to Calendar\" default answer \"$RAW_HINT\" buttons {\"Cancel\", \"Next →\"} default button \"Next →\"" -e 'text returned of result' 2>/dev/null)

if [ -z "$WHEN" ]; then
  exit 0
fi

WHERE=$(osascript -e 'display dialog "Location? (leave blank to skip)" with title "Add to Calendar" default answer "" buttons {"Skip", "Done ✓"} default button "Done ✓"' -e 'text returned of result' 2>/dev/null)

# Parse date/time into numeric fields for AppleScript
PARSED=$(python3 "$SCRIPTS_DIR/parse_when.py" "$WHEN" "$(date '+%Y-%m-%d')" 2>/dev/null)

if [ -z "$PARSED" ]; then
  osascript -e 'display dialog "Couldn'\''t parse the date/time. Event not created." with title "Calendar Error" buttons {"OK"}' 2>/dev/null
  exit 0
fi

read S_YEAR S_MON S_DAY S_HOUR S_MIN <<< "$(echo "$PARSED" | sed -n '1p')"
read E_YEAR E_MON E_DAY E_HOUR E_MIN <<< "$(echo "$PARSED" | sed -n '2p')"
HUMAN_TIME=$(echo "$PARSED" | sed -n '3p')

# Sanitize HUMAN_TIME for use in osascript dialog
HUMAN_TIME_DISPLAY="${HUMAN_TIME//\"/}"

# Confirm before creating
CONFIRM=$(osascript -e "display dialog \"Create calendar event?\\n\\n📅 $DISPLAY_TASK\\n🕐 $HUMAN_TIME_DISPLAY\\n📍 ${WHERE:-(no location)}\" with title \"Add to Calendar\" buttons {\"Cancel\", \"Create ✓\"} default button \"Create ✓\"" -e 'button returned of result' 2>/dev/null)

if [ "$CONFIRM" != "Create ✓" ]; then
  exit 0
fi

# Properly sanitize for AppleScript string literals
# Order matters: escape \ first, then "
sanitize_as() {
  printf '%s' "$1" | tr -d '\n\r' | sed 's/\\/\\\\/g; s/"/\\"/g'
}
AS_TITLE=$(sanitize_as "$TASK")
AS_LOCATION=$(sanitize_as "$WHERE")

osascript << ASEOF
tell application "Calendar"
    -- Build start date numerically (locale-safe, avoids strftime locale issues)
    set startDate to current date
    set year of startDate to $S_YEAR
    set month of startDate to $S_MON
    set day of startDate to $S_DAY
    set hours of startDate to $S_HOUR
    set minutes of startDate to $S_MIN
    set seconds of startDate to 0

    -- Build end date numerically
    set endDate to current date
    set year of endDate to $E_YEAR
    set month of endDate to $E_MON
    set day of endDate to $E_DAY
    set hours of endDate to $E_HOUR
    set minutes of endDate to $E_MIN
    set seconds of endDate to 0

    -- Find first non-system calendar
    set targetCal to missing value
    repeat with c in every calendar
        set cName to name of c
        if cName is not "Birthdays" and cName is not "Siri Suggestions" and cName is not "Holidays in Singapore" then
            set targetCal to c
            exit repeat
        end if
    end repeat
    if targetCal is missing value then
        set targetCal to first calendar
    end if

    tell targetCal
        make new event with properties {summary:"$AS_TITLE", start date:startDate, end date:endDate, location:"$AS_LOCATION"}
    end tell
    reload calendars
end tell
ASEOF

AS_STATUS=$?
if [ $AS_STATUS -eq 0 ]; then
  osascript -e "display notification \"$HUMAN_TIME\" with title \"Event created: $TASK\""
else
  osascript -e 'display dialog "Calendar event failed. Make sure Calendar.app is open and has permission." with title "Calendar Error" buttons {"OK"}' 2>/dev/null
fi
